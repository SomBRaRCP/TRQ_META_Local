# Ollama local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Banco local
LZ_DB_PATH=./data/luzia_trq.sqlite3
LZ_JSONL_PATH=./data/luzia_trq_runs.jsonl

# Desenvolvimento: 1 permite fallback determinístico quando Ollama não está aberto.
# Produção real: coloque 0 para falhar caso Ollama esteja indisponível.
LZ_ALLOW_FALLBACK=1
